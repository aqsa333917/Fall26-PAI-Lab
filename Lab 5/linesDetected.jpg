   "source": [
    "# Python program to illustrate Hough Line method for line detection\n",
    "\n",
    "import cv2\n",
    "import numpy as np\n",
    "\n",
    "# Read image\n",
    "img = cv2.imread(r\"C:\\Users\\Administrator\\Pictures\\Screenshots\\Screenshot 2026-01-28 045911.png\")\n",
    "\n",
    "# Check if image loaded properly\n",
    "if img is None:\n",
    "    print(\"Error: Image not found. Check file path.\")\n",
    "    exit()\n",
    "\n",
    "# Convert to grayscale\n",
    "gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)\n",
    "\n",
    "# Edge detection\n",
    "edges = cv2.Canny(gray, 50, 150, apertureSize=3)\n",
    "\n",
    "# Use lower threshold (200 is too high)\n",
    "lines = cv2.HoughLines(edges, 1, np.pi/180, 120)\n",
    "\n",
    "# Check if lines detected\n",
    "if lines is not None:\n",
    "    for r_theta in lines:\n",
    "        r, theta = r_theta[0]\n",
    "\n",
    "        a = np.cos(theta)\n",
    "        b = np.sin(theta)\n",
    "\n",
    "        x0 = a * r\n",
    "        y0 = b * r\n",
    "\n",
    "        x1 = int(x0 + 1000 * (-b))\n",
    "        y1 = int(y0 + 1000 * (a))\n",
    "\n",
    "        x2 = int(x0 - 1000 * (-b))\n",
    "        y2 = int(y0 - 1000 * (a))\n",
    "\n",
    "        cv2.line(img, (x1, y1), (x2, y2), (0, 0, 255), 2)\n",
    "\n",
    "    print(\"Lines detected successfully.\")\n",
    "else:\n",
    "    print(\"No lines detected in image.\")\n",
    "\n",
    "# Save output image\n",
    "cv2.imwrite(\"linesDetected.jpg\", img)\n",
    "\n",
    "# Optional: Show images\n",
    "cv2.imshow(\"Edges\", edges)\n",
    "cv2.imshow(\"Detected Lines\", img)\n",
    "cv2.waitKey(0)\n",
    "cv2.destroyAllWindows()"
   ]
  },
