   ],
   "source": [
    "import cv2\n",
    "import numpy as np\n",
    "import sys\n",
    "\n",
    "# =========================\n",
    "# 1️⃣ Load Images\n",
    "# =========================\n",
    "\n",
    "img1_color = cv2.imread(r'C:\\Users\\Administrator\\Pictures\\Screenshots\\Screenshot 2026-02-11 213943.png')\n",
    "img2_color = cv2.imread(r\"C:\\Users\\Administrator\\Pictures\\Screenshots\\{4B8F1CE3-8100-4E7D-BA0C-28B2CAC129B3}.png\")\n",
    "\n",
    "if img1_color is None or img2_color is None:\n",
    "    print(\"❌ Error loading one or both images.\")\n",
    "    sys.exit()\n",
    "\n",
    "# =========================\n",
    "# 2️⃣ Convert to Grayscale\n",
    "# =========================\n",
    "\n",
    "img1 = cv2.cvtColor(img1_color, cv2.COLOR_BGR2GRAY)\n",
    "img2 = cv2.cvtColor(img2_color, cv2.COLOR_BGR2GRAY)\n",
    "\n",
    "height, width = img2.shape\n",
    "\n",
    "# =========================\n",
    "# 3️⃣ ORB Feature Detection\n",
    "# =========================\n",
    "\n",
    "orb_detector = cv2.ORB_create(5000)\n",
    "\n",
    "kp1, d1 = orb_detector.detectAndCompute(img1, None)\n",
    "kp2, d2 = orb_detector.detectAndCompute(img2, None)\n",
    "\n",
    "if d1 is None or d2 is None:\n",
    "    print(\"❌ No descriptors found in one of the images.\")\n",
    "    sys.exit()\n",
    "\n",
    "# =========================\n",
    "# 4️⃣ Feature Matching\n",
    "# =========================\n",
    "\n",
    "matcher = cv2.BFMatcher(cv2.NORM_HAMMING, crossCheck=True)\n",
    "\n",
    "# Convert to list to avoid tuple error\n",
    "matches = list(matcher.match(d1, d2))\n",
    "\n",
    "if len(matches) == 0:\n",
    "    print(\"❌ No matches found.\")\n",
    "    sys.exit()\n",
    "\n",
    "# Sort matches by distance (lower is better)\n",
    "matches.sort(key=lambda x: x.distance)\n",
    "\n",
    "# Keep top 90% matches\n",
    "matches = matches[:int(len(matches) * 0.9)]\n",
    "no_of_matches = len(matches)\n",
    "\n",
    "if no_of_matches < 4:\n",
    "    print(\"❌ Not enough matches to compute homography.\")\n",
    "    sys.exit()\n",
    "\n",
    "# =========================\n",
    "# 5️⃣ Extract Matched Points\n",
    "# =========================\n",
    "\n",
    "p1 = np.zeros((no_of_matches, 2))\n",
    "p2 = np.zeros((no_of_matches, 2))\n",
    "\n",
    "for i in range(no_of_matches):\n",
    "    p1[i, :] = kp1[matches[i].queryIdx].pt\n",
    "    p2[i, :] = kp2[matches[i].trainIdx].pt\n",
    "\n",
    "# =========================\n",
    "# 6️⃣ Compute Homography\n",
    "# =========================\n",
    "\n",
    "homography, mask = cv2.findHomography(p1, p2, cv2.RANSAC, 5.0)\n",
    "\n",
    "if homography is None:\n",
    "    print(\"❌ Homography computation failed.\")\n",
    "    sys.exit()\n",
    "\n",
    "# =========================\n",
    "# 7️⃣ Warp Image\n",
    "# =========================\n",
    "\n",
    "transformed_img = cv2.warpPerspective(\n",
    "    img1_color,\n",
    "    homography,\n",
    "    (width, height)\n",
    ")\n",
    "\n",
    "# =========================\n",
    "# 8️⃣ Save Result\n",
    "# =========================\n",
    "\n",
    "cv2.imwrite('output.jpg', transformed_img)\n",
    "\n",
    "print(\"✅ Alignment successful. Saved as output.jpg\")\n"
   ]
  }
 ],
